# Waikiki Dental — environment variables
# Copy to .env.local for local development, or set these in the Vercel
# dashboard / `vercel env add` for preview & production.
#
# These power the contact form (/api/contact) and the appointment
# scheduler (/api/schedule). Until they are set, both forms gracefully
# fall back to opening the visitor's email app — nothing is lost.

# Resend API key (server-only — never prefix with NEXT_PUBLIC_).
# Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where appointment requests and messages should be delivered.
CONTACT_TO_EMAIL=office@waikikidental.com

# Optional verified sender. Falls back to Resend's onboarding sender.
# Use a domain you've verified in Resend, e.g. "Waikiki Dental <hello@waikikidental.com>"
CONTACT_FROM_EMAIL=
